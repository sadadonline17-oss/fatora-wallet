APP_NAME="Fatora Wallet"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://fatora-wallet.com
FRONTEND_URL=https://fatora-wallet.com

LOG_CHANNEL=daily
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fatora_wallet
DB_USERNAME=fatora
DB_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@fatora-wallet.com"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

KNET_ENABLED=true
KNET_MERCHANT_ID=your_merchant_id
KNET_SHARED_SECRET=your_shared_secret
KNET_MODULE_ID=1234
KNET_RETURN_URL=${APP_URL}
KNET_ERROR_URL=${APP_URL}
KNET_TEST_MODE=true

PAYTABS_ENABLED=false
PAYTABS_MERCHANT_EMAIL=your@email.com
PAYTABS_SECRET_KEY=your_secret_key
PAYTABS_PROFILE_ID=your_profile_id
PAYTABS_CURRENCY=KWD
PAYTABS_SITE_URL=${APP_URL}
PAYTABS_RETURN_URL=${APP_URL}
PAYTABS_TEST_MODE=true

MYFATOORAH_ENABLED=false
MYFATOORAH_API_KEY=your_api_key
MYFATOORAH_COUNTRY=KWT
MYFATOORAH_RETURN_URL=${APP_URL}
MYFATOORAH_TEST_MODE=true

DEFAULT_PAYMENT_GATEWAY=knet

WEBHOOK_SECRET=your_webhook_secret_here
